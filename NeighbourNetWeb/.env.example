# NeighbourNet Frontend — Local environment variables
# ─────────────────────────────────────────────────────────────────────────────

# FastAPI backend (start with: .venv/bin/uvicorn app.main:app --reload --port 8000)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Supabase
# URL is safe to expose — it's the public project URL.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxx.supabase.co

# Anon key — get this from:
#   Supabase Dashboard → project npwdgcjukdwxffubkmeo → Settings → API
#   Copy the "anon / public" key (NOT the service_role key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhxxxxxxxxxxx9.eyJpc3MiOxxxxxxxxxxoVRxxxxxjMU
