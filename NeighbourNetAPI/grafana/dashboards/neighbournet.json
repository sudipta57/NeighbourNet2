{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "NeighbourNet FastAPI /metrics endpoint",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" }
  ],
  "title": "NeighbourNet — Disaster Mesh Dashboard",
  "description": "Real-time observability for the NeighbourNet disaster mesh communication system. Built for Bengal flood relief. Hackathon 2026.",
  "tags": ["neighbournet", "disaster", "mesh", "bengal"],
  "timezone": "Asia/Kolkata",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "Active Mesh Nodes",
      "description": "Unique devices seen in the last 30 minutes across all gateway uploads.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 5 }
            ]
          },
          "unit": "short",
          "displayName": "Active Nodes"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "neighbournet_active_nodes",
          "legendFormat": "Active Nodes"
        }
      ]
    },

    {
      "id": 2,
      "title": "Queue Depth",
      "description": "Total unacknowledged SOS messages waiting for coordinator action.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short",
          "displayName": "Pending Messages"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "neighbournet_queue_depth_total",
          "legendFormat": "Queue Depth"
        }
      ]
    },

    {
      "id": 3,
      "title": "CRITICAL Messages",
      "description": "Total CRITICAL priority messages received (trapped / medical emergency).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "unit": "short",
          "displayName": "CRITICAL"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "neighbournet_triage_critical_total",
          "legendFormat": "CRITICAL"
        }
      ]
    },

    {
      "id": 4,
      "title": "Sync Events",
      "description": "Total gateway sync events — one per successful POST /api/messages/batch.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "unit": "short",
          "displayName": "Sync Events"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "neighbournet_sync_events_total",
          "legendFormat": "Sync Events"
        }
      ]
    },

    {
      "id": 5,
      "title": "Triage Distribution",
      "description": "Cloud-confirmed priority tier breakdown. The red slice is what coordinators act on first.",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "options": {
        "pieType": "donut",
        "displayLabels": ["name", "percent"],
        "legendDisplayMode": "table",
        "legendPlacement": "right"
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "CRITICAL" }, "properties": [{ "id": "color", "value": { "fixedColor": "#e02f44", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "HIGH" },     "properties": [{ "id": "color", "value": { "fixedColor": "#ff7f0e", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "MEDIUM" },   "properties": [{ "id": "color", "value": { "fixedColor": "#17becf", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "LOW" },      "properties": [{ "id": "color", "value": { "fixedColor": "#7f7f7f", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "neighbournet_triage_critical_total",
          "legendFormat": "CRITICAL"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "neighbournet_triage_high_total",
          "legendFormat": "HIGH"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "neighbournet_triage_medium_total",
          "legendFormat": "MEDIUM"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "neighbournet_triage_low_total",
          "legendFormat": "LOW"
        }
      ]
    },

    {
      "id": 6,
      "title": "Queue Depth Over Time",
      "description": "Time series of unacknowledged messages. Drops indicate coordinators actioning SOS messages.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity"
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "neighbournet_queue_depth_total",
          "legendFormat": "Queue Depth"
        }
      ]
    },

    {
      "id": 7,
      "title": "Gateway Sync Rate",
      "description": "Rate of gateway upload events per minute. Spikes = phones finding signal in a flood zone.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "unit": "reqpm"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(neighbournet_sync_events_total[5m]) * 60",
          "legendFormat": "Sync events / min"
        }
      ]
    },

    {
      "id": 8,
      "title": "Message Hop Latency (P50 / P95)",
      "description": "Seconds between SOS creation on device and receipt by backend. P95 captures worst-case relay chains.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, rate(neighbournet_message_hop_latency_seconds_bucket[10m]))",
          "legendFormat": "P50 Latency"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, rate(neighbournet_message_hop_latency_seconds_bucket[10m]))",
          "legendFormat": "P95 Latency"
        }
      ]
    }

  ]
}